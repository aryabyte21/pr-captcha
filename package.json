{
  "name": "pr-captcha",
  "version": "0.1.0",
  "private": true,
  "description": "Human-origin checks for GitHub pull requests.",
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces",
    "check": "npm run check --workspaces",
    "test": "node --test test/*.test.mjs && npm run test --workspaces --if-present",
    "check:deploy-env": "node scripts/deploy-preflight.mjs",
    "format": "prettier --check ."
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
